@model IEnumerable<Kutuphane1.Models.SayisalKitap>


<table class="table table-striped table-row-bordered gy-5 gs-7 dt-init">
	<thead>
		<tr class="fw-bolder fs-6 text-gray-700">
			<th>İşlem</th>
			<th>
				@Html.DisplayNameFor(model => model.Aktif)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.KAYİTTARİHİ)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.KİTAPADİ)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.ADET)
			</th>

			<th>
				@Html.DisplayNameFor(model => model.FİYAT)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.TUTAR)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.KDV)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.TOPLAMTUTAR)
			</th>


		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model)
		{
		<tr>
			<td>
				<label class="form-label">
					<input class="form-check-input" type="checkbox" id="ceSayisalKitapId" />
				</label>
			</td>
			<td style="display: none;">@item.Id</td>
			<td>
				<a asp-action="Guncelle" asp-route-id="@item.Id" data-toggle="tooltip" title="Düzenle"><i class="fas fa-pencil-alt text-primary" style="font-size:1.5rem"></i>Düzenle </a>
				@if (item.Aktif)
				{
					<a asp-controller="SayisalKitap" asp-action="DurumDegistir" asp-route-id="@item.Id" data-toggle="tooltip" title="Pasif Yap"><i class="fa fa-arrow-down text-warning ml-3" style="font-size:1.5rem"></i>DurumPasifYap </a>
				}
				else
				{
					<a asp-controller="SayisalKitap" asp-action="DurumDegistir" asp-route-id="@item.Id" data-toggle="tooltip" title="Aktif Yap"><i class="fa fa-arrow-up text-success ml-3" style="font-size:1.5rem"></i>DurumAktifYap </a>
				}

				@*<a onclick="Sil(@item.Id)" data-toggle="tooltip" title="Sil"><i class="far fa-trash-alt text-danger ml-2" style="font-size:1.5rem"></i>  </a>*@
				<a asp-action="Sil" asp-route-id="@item.Id" data-toggle="tooltip" title="Sil"><i class="fa fa-trash-alt text-danger ml-2" style="font-size:1.5rem"></i>Sil </a>


			</td>
			<td>
				@if (item.Aktif)
				{
					<label class="text-success">@item.AktifString</label>
				}
				else
				{
					<label class="text-danger">@item.AktifString</label>
				}
			</td>
			<td>
				@Html.DisplayFor(modelItem => item.KAYİTTARİHİ)
			</td>
			<td>
				@Html.DisplayFor(modelItem => item.KİTAPADİ)
			</td>
			<td>
				@Html.DisplayFor(modelItem => item.ADET)
			</td>

			<td>
				@Html.DisplayFor(modelItem => item.FİYAT)
			</td>
			<td>
				@Html.DisplayFor(modelItem => item.TUTAR)
			</td>
			<td>
				@Html.DisplayFor(modelItem => item.KDV)
			</td>
			<td>
				@Html.DisplayFor(modelItem => item.TOPLAMTUTAR)
			</td>
			
		</tr>
		}
	</tbody>
</table>

