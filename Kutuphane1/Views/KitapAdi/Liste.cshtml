@model IEnumerable<KitapAdi>
@{
    //ViewData["Title"] = "Kitap Adı Liste";
}

<div class="row">
    <div>
        <a asp-controller="KitapAdi" asp-action="Ekle" class="btn btn-primary">
            <i class="fa fa-plus"></i> Yeni Kitap Adı Ekle
        </a>
    </div>
    <div class="card-body py-3">
        <table class="table table-striped table-row-bordered gy-5 gs-7 dt-init">
            <thead>
            <tr class="fw-bolder fs-6 text-gray-700">
                <th>İşlem</th>
                <th>
                    @Html.DisplayNameFor(model => model.Aktif)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.KİTABİNADİ)
                </th>

            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <a asp-action="Guncelle" asp-route-id="@item.Id" data-toggle="tooltip" title="Düzenle" class="btn btn-sm btn-danger"><i class="fa fa-pencil-alt text-primary" style="font-size: 1.5rem"></i>Güncelle </a>
                        @if (item.Aktif)
                        {
                            <a asp-controller="KitapAdi" asp-action="DurumDegistir" asp-route-id="@item.Id" data-toggle="tooltip" title="Pasif Yap"><i class="fa fa-arrow-down text-warning ml-3" style="font-size: 1.5rem"></i>DurumPasifYap </a>
                        }
                        else
                        {
                            <a asp-controller="KitapAdi" asp-action="DurumDegistir" asp-route-id="@item.Id" data-toggle="tooltip" title="Aktif Yap"><i class="fa fa-arrow-up text-success ml-3" style="font-size: 1.5rem"></i>DurumAktifYap </a>
                        }


                        <a asp-action="Sil" asp-route-id="@item.Id" data-toggle="tooltip" title="Sil"><i class="fa fa-trash-alt text-danger ml-2" style="font-size: 1.5rem"></i>Sil </a>
                        @*<a onclick="Sil(@item.Id)" data-toggle="tooltip" title="Sil"><i class="fa fa-trash-alt text-danger ml-2" style="font-size:1.5rem"></i>Sil </a>*@
                    </td>
                    <td>
                        @if (item.Aktif)
                        {
                            <label class="text-success">@item.Aktif</label>
                        }
                        else
                        {
                            <label class="text-danger">@item.Aktif</label>
                        }
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.KİTABİNADİ)
                    </td>

                </tr>
            }
            </tbody>
        </table>
    </div>

</div>

@section Scripts{
    <script>
        $(document).ready(function() {
            InitDatatables();
        });
    </script>

}